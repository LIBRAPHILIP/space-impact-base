# Base mainnet = 8453, Base Sepolia = 84532
VITE_CHAIN_ID=8453

# Set after deploy (npm run compile && npm run deploy:base-sepolia)
VITE_NFT_ADDRESS=

# WalletConnect / Reown Project ID (free): https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=

# Firebase Auth (Google + X/Twitter) — https://console.firebase.google.com
# Enable Authentication → Sign-in method → Google and Twitter
# Add authorized domains: localhost, space-impact-base.vercel.app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Deploy only:
# PRIVATE_KEY=0x...
# RPC_URL=https://sepolia.base.org
